+import os
+import uuid
 from django.db import models
 
 
+def caminho_documento_cliente(instance, filename):
+    """Gera um caminho único para o arquivo, preservando a extensão original,
+    mas trocando o nome para evitar colisões e sobrescritas indevidas."""
+    ext = os.path.splitext(filename)[1].lower()
+    nome_unico = f"{uuid.uuid4().hex}{ext}"
+    return os.path.join('documentos_clientes', str(instance.registro_id), nome_unico)
+
